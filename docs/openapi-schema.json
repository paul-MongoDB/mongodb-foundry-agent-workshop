{
  "openapi": "3.0.0",
  "info": {
    "title": "Embedding API",
    "description": "Generate text embeddings using Azure OpenAI text-embedding-ada-002 model for vector search operations.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://YOUR_FUNCTION_APP.azurewebsites.net/api",
      "description": "Azure Function App endpoint"
    }
  ],
  "paths": {
    "/embed": {
      "post": {
        "operationId": "generateEmbedding",
        "summary": "Generate embedding vector for text",
        "description": "Takes a text string and returns a 1536-dimensional embedding vector suitable for MongoDB vector search.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "The text to generate an embedding for",
                    "example": "movies about hope and redemption"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Embedding generated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "embedding": {
                      "type": "array",
                      "items": {
                        "type": "number"
                      },
                      "description": "1536-dimensional embedding vector"
                    },
                    "dimensions": {
                      "type": "integer",
                      "description": "Number of dimensions in the embedding",
                      "example": 1536
                    },
                    "model": {
                      "type": "string",
                      "description": "Model used to generate the embedding",
                      "example": "text-embedding-ada-002"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request - missing or invalid text parameter"
          },
          "500": {
            "description": "Server error - embedding generation failed"
          }
        }
      }
    }
  }
}
