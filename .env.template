# Copy this file to .env for local deployment testing.
# Do not commit .env.

# Azure deployment target
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=mongodb-agent-rg
AZURE_LOCATION=eastus

# MongoDB Atlas
MONGODB_CONNECTION_STRING=

# Azure OpenAI embedding deployment
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_KEY=
EMBEDDING_MODEL=text-embedding-ada-002

# Optional: used after deployment if you want to save outputs locally.
MCP_SERVER_URL=
EMBEDDING_API_URL=
FUNCTION_APP_NAME=
